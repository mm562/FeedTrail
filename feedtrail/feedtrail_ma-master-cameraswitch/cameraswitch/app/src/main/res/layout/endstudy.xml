<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- App Logo/Text -->

    <!-- Welcome Text -->


    <!-- Page Indicator -->

    <TextView
        android:id="@+id/welcome_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/app_logo"
        android:layout_centerHorizontal="true"
        android:layout_marginLeft="50dp"
        android:layout_marginRight="50dp"
        android:layout_marginTop="80dp"
        android:fontFamily="@font/pacifico"
        android:text="Thank You for participating in our study!"
        android:textColor="#FF0000"
        android:textAlignment="center"
        android:textSize="28sp"
        android:textStyle="bold"
        tools:ignore="NotSibling" />

    <TextView
        android:id="@+id/textunder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/welcome_text"
        android:layout_centerHorizontal="true"
        android:layout_marginLeft="50dp"
        android:layout_marginTop="36dp"
        android:layout_marginRight="50dp"
        android:fontFamily="@font/roboto_italic"
        android:text="Please dont delete the application yet for data upload. App Permissions have been revoked\n\nYou will get notified on Prolific regarding your compensation as soon as possible"
        android:textAlignment="center"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:ignore="NotSibling"

        />

    <ImageView
        android:id="@+id/lemon_image"
        android:layout_width="match_parent"
        android:layout_height="248dp"
        android:layout_below="@id/textunder"
        android:layout_marginTop="11dp"
        android:src="@drawable/welcome" />




</RelativeLayout>
